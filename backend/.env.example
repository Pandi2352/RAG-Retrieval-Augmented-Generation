# ---- Server ----
PORT=5000
CORS_ORIGIN=http://localhost:5173

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/ollama_rag

# ---- Qdrant ----
# Switch vector store by flipping QDRANT_MODE between "local" and "cloud".
QDRANT_MODE=local
QDRANT_COLLECTION=documents

# local (Docker:  docker compose up -d)
QDRANT_LOCAL_URL=http://localhost:6333

# cloud (https://cloud.qdrant.io) — used only when QDRANT_MODE=cloud
QDRANT_CLOUD_URL=https://your-cluster-id.region.gcp.cloud.qdrant.io:6333
QDRANT_CLOUD_API_KEY=your_qdrant_cloud_api_key

# ---- Ollama: CHAT (cloud) ----
OLLAMA_CHAT_HOST=https://ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_CHAT_MODEL=gemma3:27b

# ---- Ollama: EMBEDDINGS (cloud) ----
OLLAMA_EMBED_HOST=https://ollama.com
OLLAMA_EMBED_MODEL=Xenova/all-MiniLM-L6-v2
EMBED_DIM=384


# ---- Ollama: OCR (cloud vision model) ----
OLLAMA_OCR_HOST=https://ollama.com
OLLAMA_OCR_MODEL=gemma3:27b

# ---- RAG tuning ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
SCORE_THRESHOLD=0.2
MAX_UPLOAD_MB=25
